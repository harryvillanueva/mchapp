<style>
      h5 {
            color: #f18420;
            font-weight: bold;
      }

      .show {
            display: block;
      }

      .hide {
            display: none;
      }

      button.btn-enviar {
            margin-top: 0;
            margin-left: 1%;
      }

      button {
            margin-top: 0%;
      }

      #accion,
      #location,
      #typecard,
      #typecode {
            width: 100%;
            padding-top: 0.3rem;
            padding-bottom: 0.3rem;
            padding-left: 0.5rem;
            font-size: 1rem;
      }

      div.txt-left {
            text-align: left;
      }

      span.not-exist {
            font-size: 1.8rem;
            font-weight: normal;
      }

      .mt-2 {
            padding-bottom: 20px;
      }

      .sincronzarTimeStamp {
            margin-top: 10px;
      }

      .btns-cp {
            margin-bottom: 5px;
      }

      img.link-luz {
            width: 70px;
            cursor: pointer;
            top: -10px;
            position: relative;
      }

      span.txt-link-luz {
            font-size: 14px;
            margin-left: -20px;
            margin-top: 35px;
            position: absolute;
      }

      @media screen and (max-width: 600px) {
            h1.head-title {
                  margin-top: 25px;
                  font-size: 20px;
            }

            span.txt-link-luz {
                  font-size: 12px;
            }
      }

      .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: none;
            background: rgba(0, 0, 0, 0.5);
            justify-content: center;
            align-items: center;
            z-index: 1050;
      }

      .modal .modal-dialog {
            background: #fff;
            border-radius: 8px;
            overflow: hidden;
            max-width: 500px;
            width: 90%;
      }

      .modal .modal-header {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 1rem;
            position: relative;
      }

      .modal .modal-header .modal-title {
            font-size: 1.5rem;
            text-align: center;
            margin: 0 auto;
      }

      .modal .modal-header .btn-close {
            position: absolute;
            right: 1rem;
            top: 1rem;
      }

      .modal.show {
            display: flex;
      }
</style>


