    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" 
        rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
    <title>My City Home</title>
    <link rel="shortcut icon" href="https://ibb.co/zRHrrWf">
    <link rel="stylesheet" href="" type="text/css">
    {{#each scripts}}
        <script src="{{script}}"></script>
    {{/each}}
    <style>
    body {
        height: 90vh;
        /*width: 100vw;*/
    }

    #formulario {
        font-weight: bold;
    }

    button {
        margin-top: 5%;
    }

    .container {
            width: 75%;
            margin-top: 30px;
            text-align: center;
    }

    .text-success {
            color: #0f5132;
      }

      .text-danger {
            color: #842029;
    }

    /*Estilo para tabla con DIVs*/
      #contenedor-table {
            display: none;
            /*text-align: center;*/
            margin: 0 auto;
      }

      .row-table-div {
            margin-bottom: 25px;
      }

      .col-nro-table {
            border-right: 3px solid black;
            text-align: left;
            font-weight: bold;
            min-width: 45px;
      }

      #contenedor-table div.row-table-div:nth-child(odd) {
            background-color: #f2f2f2;
      }

      .txt-value {
            padding-left: 20px;
      }
      /* Fin de estilo con tabla*/
</style>
</head>
<body>
    {{{body}}}
</body>
